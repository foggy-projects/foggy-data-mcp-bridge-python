{
  "suite": "timeWindow",
  "source": {
    "repo": "foggy-data-mcp-bridge-wt-dev-compose",
    "version": "8.5.0.beta",
    "path": "foggy-dataset-model/src/test/resources/parity/timeWindow",
    "contract": "docs/8.4.0.beta/P2-timeWindow-calculatedFields-interaction-contract.md",
    "implementationCommit": "ba7831e",
    "acceptance": "docs/8.3.0.beta/acceptance/P1-SemanticDSL-TimeWindow-Java-acceptance.md"
  },
  "cases": [
    {
      "description": "MoM happy path",
      "comparison": "mom",
      "grain": "month",
      "label": "happy",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "mom",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedColumns": [
        "salesDate$month",
        "salesDate$id",
        "salesAmount",
        "salesAmount__prior",
        "salesAmount__diff",
        "salesAmount__ratio"
      ],
      "name": "mom-month-happy"
    },
    {
      "description": "NEGATIVE: mom × week grain is incompatible",
      "comparison": "mom",
      "grain": "week",
      "label": "negative-grain-incompat",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "week",
        "comparison": "mom",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedError": "TIMEWINDOW_GRAIN_INCOMPATIBLE",
      "name": "mom-week-negative-grain-incompat"
    },
    {
      "description": "MTD + day grain happy path",
      "comparison": "mtd",
      "grain": "day",
      "label": "happy",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "day",
        "comparison": "mtd",
        "range": "[)",
        "value": [
          "2024-01-01",
          "now"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedColumns": [
        "salesAmount__mtd"
      ],
      "name": "mtd-day-happy"
    },
    {
      "description": "Rolling 30-day happy path",
      "comparison": "rolling_30d",
      "grain": "day",
      "label": "happy",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "day",
        "comparison": "rolling_30d",
        "range": "[)",
        "value": [
          "-60D",
          "now"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedColumns": [
        "salesAmount__rolling_30d"
      ],
      "assertions": {
        "windowFrame": "ROWS BETWEEN 29 PRECEDING AND CURRENT ROW",
        "rollingMode": "observed"
      },
      "name": "rolling_30d-day-happy"
    },
    {
      "description": "Rolling 7-day happy path",
      "comparison": "rolling_7d",
      "grain": "day",
      "label": "happy",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "day",
        "comparison": "rolling_7d",
        "range": "[)",
        "value": [
          "-30D",
          "now"
        ],
        "targetMetrics": [
          "salesAmount"
        ],
        "rollingAggregator": "avg"
      },
      "expectedColumns": [
        "salesAmount__rolling_7d"
      ],
      "assertions": {
        "windowFrame": "ROWS BETWEEN 6 PRECEDING AND CURRENT ROW",
        "rollingMode": "observed"
      },
      "name": "rolling_7d-day-happy"
    },
    {
      "description": "NEGATIVE: rolling_7d × month grain is incompatible",
      "comparison": "rolling_7d",
      "grain": "month",
      "label": "negative-grain-incompat",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "rolling_7d",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedError": "TIMEWINDOW_GRAIN_INCOMPATIBLE",
      "name": "rolling_7d-month-negative-grain-incompat"
    },
    {
      "description": "rolling_7d + post calc field: rollingGap = salesAmount - salesAmount__rolling_7d",
      "comparison": "rolling_7d",
      "grain": "day",
      "label": "happy-post-calc-gap",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "day",
        "comparison": "rolling_7d",
        "range": "[)",
        "value": [
          "-1M",
          "now"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "calculatedFields": [
        {
          "name": "rollingGap",
          "expression": "salesAmount - salesAmount__rolling_7d"
        }
      ],
      "expectedColumns": [
        "salesDate$id",
        "salesAmount",
        "salesAmount__rolling_7d",
        "rollingGap"
      ],
      "assertions": {
        "postCalcFieldPresent": true,
        "rollingGapEqualsAmountMinusRolling": true
      },
      "name": "rolling_7d-post-calc-gap-happy"
    },
    {
      "description": "WoW + week grain happy path",
      "comparison": "wow",
      "grain": "week",
      "label": "happy",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "week",
        "comparison": "wow",
        "range": "[)",
        "value": [
          "-2W",
          "now"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedColumns": [
        "salesDate$week",
        "salesDate$dayOfWeek",
        "salesAmount",
        "salesAmount__prior",
        "salesAmount__diff",
        "salesAmount__ratio"
      ],
      "name": "wow-week-happy"
    },
    {
      "description": "NEGATIVE: yoy × day grain is incompatible",
      "comparison": "yoy",
      "grain": "day",
      "label": "negative-grain-incompat",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "day",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedError": "TIMEWINDOW_GRAIN_INCOMPATIBLE",
      "name": "yoy-day-negative-grain-incompat"
    },
    {
      "description": "YoY + month grain happy path with single metric",
      "comparison": "yoy",
      "grain": "month",
      "label": "happy-single-metric",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedColumns": [
        "salesDate$year",
        "salesDate$month",
        "salesAmount",
        "salesAmount__prior",
        "salesAmount__diff",
        "salesAmount__ratio"
      ],
      "assertions": {
        "joinOn": [
          "salesDate$month"
        ],
        "ratioNullWhenPriorZero": true,
        "ratioNullWhenPriorNull": true
      },
      "name": "yoy-month-happy"
    },
    {
      "description": "NEGATIVE: invalid range (] is not allowed",
      "comparison": "yoy",
      "grain": "month",
      "label": "negative-range-invalid",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "(]",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedError": "TIMEWINDOW_RANGE_INVALID",
      "name": "yoy-month-negative-range-invalid"
    },
    {
      "description": "YoY + month grain + post calc field: growthPercent = salesAmount__ratio * 100",
      "comparison": "yoy",
      "grain": "month",
      "label": "happy-post-calc-growth",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "calculatedFields": [
        {
          "name": "growthPercent",
          "expression": "salesAmount__ratio * 100"
        }
      ],
      "expectedColumns": [
        "salesDate$year",
        "salesDate$month",
        "salesAmount",
        "salesAmount__prior",
        "salesAmount__diff",
        "salesAmount__ratio",
        "growthPercent"
      ],
      "assertions": {
        "postCalcFieldPresent": true,
        "growthPercentEqualsRatioTimes100": true
      },
      "name": "yoy-month-post-calc-growth-happy"
    },
    {
      "description": "Negative: post calc field uses agg (not allowed in timeWindow context)",
      "comparison": "yoy",
      "grain": "month",
      "label": "negative-post-calc-agg",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "calculatedFields": [
        {
          "name": "avgRatio",
          "expression": "salesAmount__ratio",
          "agg": "AVG"
        }
      ],
      "expectedError": "TIMEWINDOW_POST_CALCULATED_FIELD_AGG_UNSUPPORTED",
      "name": "yoy-post-calc-agg-negative"
    },
    {
      "description": "Negative: post calc field references column not in timeWindow output",
      "comparison": "yoy",
      "grain": "month",
      "label": "negative-post-calc-not-found",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "calculatedFields": [
        {
          "name": "badCalc",
          "expression": "nonExistentColumn * 100"
        }
      ],
      "expectedError": "TIMEWINDOW_POST_CALCULATED_FIELD_NOT_FOUND",
      "name": "yoy-post-calc-field-not-found-negative"
    },
    {
      "description": "Negative: post calc field uses window clause (not allowed in timeWindow context)",
      "comparison": "yoy",
      "grain": "month",
      "label": "negative-post-calc-window",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "calculatedFields": [
        {
          "name": "rankByRatio",
          "expression": "RANK()",
          "partitionBy": [
            "product$category"
          ],
          "windowOrderBy": [
            {
              "field": "salesAmount__ratio",
              "dir": "desc"
            }
          ]
        }
      ],
      "expectedError": "TIMEWINDOW_POST_CALCULATED_FIELD_WINDOW_UNSUPPORTED",
      "name": "yoy-post-calc-window-negative"
    },
    {
      "description": "Negative: targetMetrics references a calculatedField name",
      "comparison": "yoy",
      "grain": "month",
      "label": "negative-target-calc-field",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "yoy",
        "range": "[)",
        "value": [
          "2024-01-01",
          "2025-01-01"
        ],
        "targetMetrics": [
          "unitPrice"
        ]
      },
      "calculatedFields": [
        {
          "name": "unitPrice",
          "expression": "salesAmount / quantity"
        }
      ],
      "expectedError": "TIMEWINDOW_TARGET_CALCULATED_FIELD_UNSUPPORTED",
      "name": "yoy-target-calc-field-negative"
    },
    {
      "description": "YTD + month grain happy path",
      "comparison": "ytd",
      "grain": "month",
      "label": "happy",
      "timeWindow": {
        "field": "salesDate$id",
        "grain": "month",
        "comparison": "ytd",
        "range": "[)",
        "value": [
          "2024-01-01",
          "now"
        ],
        "targetMetrics": [
          "salesAmount"
        ]
      },
      "expectedColumns": [
        "salesAmount__ytd"
      ],
      "name": "ytd-month-happy"
    }
  ]
}
